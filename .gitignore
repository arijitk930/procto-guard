# ==========================================
# ProctoGuard Monorepo .gitignore
# ==========================================

# 1. Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# 2. Environment Variables (SECURITY: Never commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
backend/.env

# 3. Next.js (Frontend) Build Output & Caches
frontend/.next/
frontend/out/
frontend/build/
frontend/.tsbuildinfo
frontend/next-env.d.ts

# 4. Vercel (Frontend Deployment)
frontend/.vercel/

# 5. Express/TypeScript (Backend) Build Output
# (When you compile your backend TS code to JS for production)
backend/dist/
backend/build/
backend/.tsbuildinfo

# 6. Logs & Debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# 7. Testing & Coverage (Future-proofing)
coverage/
frontend/coverage/
backend/coverage/

# 8. OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 9. Editor/IDE Configs (Keeps your teammates' VS Code settings out)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?